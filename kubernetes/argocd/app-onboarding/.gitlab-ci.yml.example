# =============================================================================
# GitLab CI 完整模板 — ArgoCD GitOps push-back 模式
# 来源:从 vue3-demo(Vue3 + Vite 前端 SaaS)脱敏抽出,生产已验证
#
# 用法:
#   cp .gitlab-ci.yml.example /path/to/your-business-repo/.gitlab-ci.yml
#   cd /path/to/your-business-repo
#   sed -i 's/myapp/<your-app-name>/g' .gitlab-ci.yml
#
# 然后按业务技术栈改 install / build 两段:
#   ▸ Node.js / 前端:照抄 npm install + npm run build,镜像 node:18-alpine
#   ▸ Java / Maven:见 D:\code\linux\devops\gitlab-ci\dsp\.gitlab-ci.yml(多模块依赖链 + Kaniko)
#   ▸ Go / Python:换镜像 + 换 build 命令即可,其它 stage 通用
#
# GitLab 项目一次性 UI 配置见 D 段顶部注释。
# 完整文档 + 12 条踩坑表见同目录 README.md。
# =============================================================================

default:
  tags:
    - docker

stages:
  - install
  - build
  - scan
  - image
  - update-manifest

variables:
  APP_NAME: myapp                                                      # ← 改成你的应用名
  HARBOR_REGISTRY: hub.wishfoxs.com:6443
  HARBOR_PROJECT: library                                              # ← 改成你的 Harbor 项目名
  # IMAGE_TAG 双轨策略:
  #   ① 默认(branch push):IMAGE_TAG = ${CI_COMMIT_REF_SLUG}-${CI_COMMIT_SHORT_SHA},如 master-ff49f0b5
  #   ② tag push:build-image / update-manifest 两个 job 的 rules:variables 把 IMAGE_TAG 覆盖成 $CI_COMMIT_TAG
  #
  # ⚠ 不要用 ${CI_COMMIT_TAG:-fallback} 这种 bash 默认值语法,GitLab CI variables 段不解析,
  #    结果是整个 IMAGE_TAG 变成空字符串(踩过坑 → ArgoCD failed to unmarshal nil)。
  IMAGE_TAG: "${CI_COMMIT_REF_SLUG}-${CI_COMMIT_SHORT_SHA}"
  IMAGE_NAME: "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${APP_NAME}:${IMAGE_TAG}"
  NPM_CONFIG_CACHE: .npm                                               # ← 非 Node 栈可删

cache:
  key: npm-${CI_COMMIT_REF_SLUG}
  paths:
    - .npm/                                                            # ← 按业务栈改 .m2 / .gradle / pip-cache 等
    - node_modules/

# ─────────────────────────────────────────────────────────────────────
# A) install:依赖安装(按业务栈替换)
# ─────────────────────────────────────────────────────────────────────
install:
  stage: install
  image: hub.wishfoxs.com:6443/middleware/node:18-alpine               # ← 按栈换 maven:3.9-eclipse-temurin-17 / golang:1.22 / python:3.12 等
  script:
    - npm install --registry=https://registry.npmmirror.com            # ← 按栈换 mvn / go mod download / pip install 等
  artifacts:
    expire_in: 1 hour
    paths:
      - node_modules/                                                  # ← 按栈换 target/ / vendor/ / .venv/ 等

# ─────────────────────────────────────────────────────────────────────
# B) build:产物构建(按业务栈替换)
# ─────────────────────────────────────────────────────────────────────
build:
  stage: build
  image: hub.wishfoxs.com:6443/middleware/node:18-alpine
  needs:
    - job: install
      artifacts: true
  script:
    - npm run build                                                    # ← 按栈换 mvn package / go build / pyinstaller 等
  artifacts:
    expire_in: 1 day
    paths:
      - dist/                                                          # ← 按栈换 target/*.jar / bin/myapp / dist/ 等

# ─────────────────────────────────────────────────────────────────────
# C) sonar-scan:代码质量(可选,SonarQube 没配 SONAR_HOST_URL 自动跳过)
# ─────────────────────────────────────────────────────────────────────
sonar-scan:
  stage: scan
  image:
    name: hub.wishfoxs.com:6443/middleware/sonar-scanner-cli:latest
    entrypoint: [""]
  needs:
    - job: build
      artifacts: true
  script:
    - sonar-scanner -Dsonar.projectKey=${APP_NAME} -Dsonar.sources=src -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.token=${SONAR_TOKEN}
  rules:
    - if: '$SONAR_HOST_URL && $SONAR_TOKEN'

# ─────────────────────────────────────────────────────────────────────
# D) build-image:Kaniko 构镜像 + 推 Harbor(通用,基本不用改)
#
# 前置 CI/CD Variables:
#   HARBOR_USERNAME / HARBOR_PASSWORD  Variable + Masked + Protected
# ─────────────────────────────────────────────────────────────────────
build-image:
  stage: image
  image:
    name: hub.wishfoxs.com:6443/middleware/executor:debug
    entrypoint: [""]
  needs:
    - job: build
      artifacts: true
  # rules:variables 双轨切换 IMAGE_TAG:
  #   tag pipeline   → IMAGE_TAG = $CI_COMMIT_TAG(如 v1.0.0)
  #   branch master  → IMAGE_TAG = 顶部 variables 默认值(branch-sha)
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  script:
    - echo "IMAGE_NAME=${IMAGE_NAME}"
    - test -n "${HARBOR_USERNAME}" && echo "HARBOR_USERNAME is set" || echo "HARBOR_USERNAME is empty"
    - test -n "${HARBOR_PASSWORD}" && echo "HARBOR_PASSWORD is set" || echo "HARBOR_PASSWORD is empty"
    - mkdir -p /kaniko/.docker
    - |
      cat > /kaniko/.docker/config.json << EOF
      {"auths":{"${HARBOR_REGISTRY}":{"username":"${HARBOR_USERNAME}","password":"${HARBOR_PASSWORD}"}}}
      EOF
    - /kaniko/executor --context "${CI_PROJECT_DIR}" --dockerfile "${CI_PROJECT_DIR}/Dockerfile" --destination "${IMAGE_NAME}" --cache=true --verbosity=info

# ─────────────────────────────────────────────────────────────────────
# E) update-manifest:GitOps 核心 — 改 k8s/deployment.yaml + push,ArgoCD 监听 sync
#
# 前置(GitLab 项目设置,一次性):
#   ① 创建 Project Access Token
#      Settings → Access Tokens → Add new token
#        Role     = Maintainer       (master 是 protected branch,Developer 推不上去)
#        Scopes   = write_repository (只勾这一个,不要给 api)
#        Expire   = 90 天后,到期前轮换
#      复制生成的 token,同时记下自动创建的 bot username: project_<id>_bot_<hash>
#
#   ② master Protected branch 加 bot user(确认 / 兜底)
#      Settings → Repository → Protected branches → master 行
#        Allowed to push and merge 已含 Maintainers → bot 自动覆盖
#        否则 Add member 显式加 project_<id>_bot_<hash>
#
#   ③ 加 CI/CD Variable
#      Settings → CI/CD → Variables → Add variable
#        Key       = GITLAB_PUSH_TOKEN
#        Value     = ① 步生成的 token
#        Type      = Variable
#        Protected = ✅ Yes   (master protected 强制要求,不勾 pipeline 拿不到值)
#        Masked    = ✅ Yes
#
# 撞 commit 风险:如果在 build-image 跑的同时 master 被人推了新 commit,update-manifest 这步 push 会被 GitLab 拒
# (non-fast-forward)。脚本里加了 pull --rebase + retry 一次。
# ─────────────────────────────────────────────────────────────────────
update-manifest:
  stage: update-manifest
  image: hub.wishfoxs.com:6443/middleware/alpine:latest
  needs:
    - job: build-image
      artifacts: false
  # rules:variables 双轨切换 IMAGE_TAG(必须跟 build-image 段一致,否则改的 tag 跟实际推的镜像对不上)
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  variables:
    GIT_STRATEGY: clone   # 干净 clone,避免 CI cache 把 manifest 状态弄脏
    MANIFEST_FILE: k8s/deployment.yaml
  before_script:
    - apk add --no-cache git sed bash
    - git config --global user.email "gitlab-ci@myapp"
    - git config --global user.name  "GitLab CI"
  script:
    - |
      set -eu

      # token 必须有,否则一上来就报错而不是 push 到一半才 401 / 蒙在鼓里
      [ -n "${GITLAB_PUSH_TOKEN:-}" ] || {
        echo "ERROR: GITLAB_PUSH_TOKEN 未注入"
        echo "       master 是 protected branch → CI Variable 必须勾 Protected=Yes"
        echo "       检查路径:Settings → CI/CD → Variables → GITLAB_PUSH_TOKEN"
        exit 1
      }

      # IMAGE_TAG 不能空(空字符串会把 manifest 写成 myapp: 空 tag,ArgoCD 解析炸)
      # 历史事故:bash 默认值语法 ${VAR:-fb} 在 variables 段不解析,导致 IMAGE_TAG=""
      [ -n "${IMAGE_TAG:-}" ] || {
        echo "ERROR: IMAGE_TAG 空,不能改 manifest"
        echo "       检查 .gitlab-ci.yml variables 段 IMAGE_TAG 表达式"
        exit 1
      }

      echo "更新 ${MANIFEST_FILE} 镜像 tag → ${IMAGE_TAG}"

      # sed 替换 image 那一行(只动 myapp: 后面的 tag,不动别的镜像)
      sed -i "s|\(myapp:\)[^\"' ]\+|\1${IMAGE_TAG}|" "${MANIFEST_FILE}"

      # 校验:替换后必须能 grep 到新 tag
      grep -q "myapp:${IMAGE_TAG}" "${MANIFEST_FILE}" || {
        echo "ERROR: image tag 替换失败,manifest 没改动"; exit 1; }

      # 没改动就跳过(同一个 sha 重跑,tag 相同)
      if git diff --quiet "${MANIFEST_FILE}"; then
        echo "manifest 已是目标 tag,跳过 push"
        exit 0
      fi

      git add "${MANIFEST_FILE}"
      git commit -m "chore(deploy): bump image tag → ${IMAGE_TAG} [skip ci]"

      # push 用 oauth2 + token(不要把 token 写进 remote url 明文,内嵌引用)
      # 协议走 ${CI_SERVER_PROTOCOL} 自动取(自托管 GitLab 跑 http:9980,以后上 TLS 自动切 https,无需改脚本)
      AUTH_URL="${CI_SERVER_PROTOCOL}://oauth2:${GITLAB_PUSH_TOKEN}@${CI_SERVER_HOST}:${CI_SERVER_PORT}/${CI_PROJECT_PATH}.git"

      # 撞 commit 重试一次:pull --rebase 再 push
      git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME} || {
        echo "push 撞 commit,pull --rebase 重试"
        git pull --rebase "${AUTH_URL}" "${CI_COMMIT_REF_NAME}"
        git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME}
      }

      echo "manifest 已 push,ArgoCD 会在轮询周期(默认 3 分钟)内 sync"
      echo "立即触发:argocd app sync myapp  或 UI 点 REFRESH"
