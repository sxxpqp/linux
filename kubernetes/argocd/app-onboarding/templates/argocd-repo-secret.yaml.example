# ArgoCD repo 凭据(声明式)
#
# ⚠ 这是模板(.example 后缀),含明文密码,**不要把真值入 git**。
#    业务仓库 .gitignore 应当忽略 k8s/argocd-repo-secret.yaml(无 .example):
#       k8s/*-secret.yaml
#       !k8s/*-secret.yaml.example
#
# 用法:
#   cp argocd-repo-secret.yaml.example /path/to/your-repo/k8s/
#   cd /path/to/your-repo
#   cp k8s/argocd-repo-secret.yaml.example k8s/argocd-repo-secret.yaml
#   sed -i 's/myapp/<your-app-name>/g' k8s/argocd-repo-secret.yaml
#   vim k8s/argocd-repo-secret.yaml   # 改 url / username / password 三字段
#   kubectl apply -f k8s/argocd-repo-secret.yaml
#   argocd repo list   # STATUS=Successful = 通
#
# ArgoCD 看 argocd ns 下带 label argocd.argoproj.io/secret-type=repository 的 Secret,
# 自动注册为 repo,不需要 argocd repo add 也不需要 UI 点。
#
# 字段:
#   url       必填,git repo URL,要跟 Application.spec.source.repoURL 完全一致
#   username  HTTP Basic Auth 用户名(GitLab 用户名或 PAT 用户名都行)
#   password  HTTP Basic Auth 密码(用户密码 或 Personal Access Token,scope=read_repository 即可)
#
# 推荐:建一个专门的"argocd-bot" GitLab 账号 + read_repository 范围的 PAT,而不是真人账号。

apiVersion: v1
kind: Secret
metadata:
  name: repo-myapp
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  url: http://192.168.150.252:9980/<group>/myapp.git
  username: REPLACE_ME_gitlab_user
  password: REPLACE_ME_personal_access_token_or_password
