# =============================================================================
# GitLab CI 完整模板 — Python(FastAPI / Flask / Django / Celery / CLI 等)
#
# 用法:
#   cp python.yml.example /path/to/your-app/.gitlab-ci.yml
#   sed -i 's/myapp/<your-app-name>/g' /path/to/your-app/.gitlab-ci.yml
#
# 假设项目结构:
#   ./
#   ├── requirements.txt           或 pyproject.toml(poetry)
#   ├── src/                       业务源码
#   ├── tests/                     pytest
#   └── Dockerfile                  COPY 源码 + pip install + ENTRYPOINT
#
# Python 是脚本语言通常不"编译产物",test stage 跑 pytest,镜像里再 pip install。
# 替代路径(本模板未走,要的话改):
#   ▸ Poetry:replace pip install with poetry install --no-root
#   ▸ pyinstaller 单二进制:build stage 跑 pyinstaller --onefile,产物 dist/myapp
#   ▸ wheel / sdist:python -m build 出 dist/*.whl,镜像 COPY + pip install whl
# =============================================================================

default:
  tags:
    - docker

stages:
  - test
  - scan
  - image
  - update-manifest

variables:
  APP_NAME: myapp
  HARBOR_REGISTRY: hub.wishfoxs.com:6443
  HARBOR_PROJECT: library
  IMAGE_TAG: "${CI_COMMIT_REF_SLUG}-${CI_COMMIT_SHORT_SHA}"
  IMAGE_NAME: "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${APP_NAME}:${IMAGE_TAG}"
  # pip 走清华源国内加速
  PIP_INDEX_URL: "https://pypi.tuna.tsinghua.edu.cn/simple"
  PIP_CACHE_DIR: "${CI_PROJECT_DIR}/.pip-cache"
  PYTHONDONTWRITEBYTECODE: "1"

cache:
  key: "pip-${CI_COMMIT_REF_SLUG}"
  paths:
    - .pip-cache/

# ─────────────────────────────────────────────────────────────────────
# A) test:pip install + pytest(没 pytest 就只 lint;要 lint 用 ruff/black)
# ─────────────────────────────────────────────────────────────────────
test:
  stage: test
  image: hub.wishfoxs.com:6443/middleware/python:3.12-slim
  before_script:
    - apt-get update -qq && apt-get install -y --no-install-recommends gcc       # 装 wheel 时偶尔要编译
    - python -m pip install --upgrade pip
    - pip install -r requirements.txt
    - pip install pytest ruff
  script:
    - ruff check src/                                                            # 风格检查,失败 stage 红
    - pytest tests/ -v --tb=short                                                # 测试,失败 stage 红
  artifacts:
    when: always
    reports:
      junit: report.xml                                                          # pytest-junit-xml 插件生成

# ─────────────────────────────────────────────────────────────────────
# C) sonar-scan:SonarQube(没配自动跳过)
# ─────────────────────────────────────────────────────────────────────
sonar-scan:
  stage: scan
  image:
    name: hub.wishfoxs.com:6443/middleware/sonar-scanner-cli:latest
    entrypoint: [""]
  needs:
    - job: test
  script:
    - sonar-scanner -Dsonar.projectKey=${APP_NAME} -Dsonar.sources=src -Dsonar.python.version=3.12 -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.token=${SONAR_TOKEN}
  rules:
    - if: '$SONAR_HOST_URL && $SONAR_TOKEN'

# ─────────────────────────────────────────────────────────────────────
# D) build-image:Kaniko + Harbor
#
# 推荐 Dockerfile:
#   FROM hub.wishfoxs.com:6443/middleware/python:3.12-slim
#   ENV PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
#   WORKDIR /app
#   COPY requirements.txt .
#   RUN pip install --no-cache-dir -r requirements.txt
#   COPY src/ ./src/
#   EXPOSE 8080
#   ENTRYPOINT ["python", "-m", "src.main"]
#
# pyinstaller 单二进制场景:build stage 加 `pyinstaller --onefile src/main.py`,
# 产物 dist/myapp,Dockerfile 改 FROM alpine + COPY dist/myapp。
# ─────────────────────────────────────────────────────────────────────
build-image:
  stage: image
  image:
    name: hub.wishfoxs.com:6443/middleware/executor:debug
    entrypoint: [""]
  needs:
    - job: test
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  script:
    - echo "IMAGE_NAME=${IMAGE_NAME}"
    - mkdir -p /kaniko/.docker
    - |
      cat > /kaniko/.docker/config.json << EOF
      {"auths":{"${HARBOR_REGISTRY}":{"username":"${HARBOR_USERNAME}","password":"${HARBOR_PASSWORD}"}}}
      EOF
    - /kaniko/executor --context "${CI_PROJECT_DIR}" --dockerfile "${CI_PROJECT_DIR}/Dockerfile" --destination "${IMAGE_NAME}" --cache=true --verbosity=info

# ─────────────────────────────────────────────────────────────────────
# E) update-manifest:GitOps 核心(栈无关)
# 前置 GitLab UI 一次性配置:见 ../README.md § 接入流程 第 3 步
# ─────────────────────────────────────────────────────────────────────
update-manifest:
  stage: update-manifest
  image: hub.wishfoxs.com:6443/middleware/alpine:latest
  needs:
    - job: build-image
      artifacts: false
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  variables:
    GIT_STRATEGY: clone
    MANIFEST_FILE: k8s/deployment.yaml
  before_script:
    - apk add --no-cache git sed bash
    - git config --global user.email "gitlab-ci@myapp"
    - git config --global user.name  "GitLab CI"
  script:
    - |
      set -eu

      [ -n "${GITLAB_PUSH_TOKEN:-}" ] || {
        echo "ERROR: GITLAB_PUSH_TOKEN 未注入 — 检查 Variable Protected=Yes"; exit 1; }
      [ -n "${IMAGE_TAG:-}" ] || {
        echo "ERROR: IMAGE_TAG 空 — 检查 variables 段表达式"; exit 1; }

      echo "更新 ${MANIFEST_FILE} → ${IMAGE_TAG}"
      sed -i "s|\(myapp:\)[^\"' ]\+|\1${IMAGE_TAG}|" "${MANIFEST_FILE}"
      grep -q "myapp:${IMAGE_TAG}" "${MANIFEST_FILE}" || { echo "ERROR: 替换失败"; exit 1; }

      if git diff --quiet "${MANIFEST_FILE}"; then
        echo "manifest 已是目标 tag,跳过 push"; exit 0; fi

      git add "${MANIFEST_FILE}"
      git commit -m "chore(deploy): bump image tag → ${IMAGE_TAG} [skip ci]"

      AUTH_URL="${CI_SERVER_PROTOCOL}://oauth2:${GITLAB_PUSH_TOKEN}@${CI_SERVER_HOST}:${CI_SERVER_PORT}/${CI_PROJECT_PATH}.git"
      git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME} || {
        echo "push 撞 commit,pull --rebase 重试"
        git pull --rebase "${AUTH_URL}" "${CI_COMMIT_REF_NAME}"
        git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME}
      }
      echo "manifest 已 push,ArgoCD 轮询周期内 sync(立即触发:argocd app sync myapp)"
