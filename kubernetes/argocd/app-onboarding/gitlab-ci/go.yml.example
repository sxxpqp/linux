# =============================================================================
# GitLab CI 完整模板 — Go
#
# 用法:
#   cp go.yml.example /path/to/your-app/.gitlab-ci.yml
#   sed -i 's/myapp/<your-app-name>/g' /path/to/your-app/.gitlab-ci.yml
#
# 假设项目结构:
#   ./
#   ├── go.mod
#   ├── go.sum
#   ├── cmd/myapp/main.go          # 主入口
#   └── Dockerfile                  # 多阶段:builder + distroless/alpine
#
# 单二进制走多阶段 Dockerfile:builder 阶段编译,final 阶段 COPY 二进制(几 MB),省镜像。
# Kaniko 也能跑多阶段。
# =============================================================================

default:
  tags:
    - docker

stages:
  - build
  - scan
  - image
  - update-manifest

variables:
  APP_NAME: myapp
  HARBOR_REGISTRY: hub.wishfoxs.com:6443
  HARBOR_PROJECT: library
  IMAGE_TAG: "${CI_COMMIT_REF_SLUG}-${CI_COMMIT_SHORT_SHA}"
  IMAGE_NAME: "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${APP_NAME}:${IMAGE_TAG}"
  # Go module proxy 走国内,跨墙慢
  GOPROXY: "https://goproxy.cn,direct"
  GOSUMDB: "off"                                                      # 内网常没法访问 sum.golang.org
  GOCACHE: "${CI_PROJECT_DIR}/.go-build-cache"
  GOMODCACHE: "${CI_PROJECT_DIR}/.go-mod-cache"
  CGO_ENABLED: "0"                                                    # 纯静态,跑 distroless / scratch 镜像
  GOOS: "linux"

cache:
  key: "go-${CI_COMMIT_REF_SLUG}"
  paths:
    - .go-build-cache/
    - .go-mod-cache/

# ─────────────────────────────────────────────────────────────────────
# A) build:go mod download + go build,产物 bin/myapp 静态二进制
# ─────────────────────────────────────────────────────────────────────
build:
  stage: build
  image: hub.wishfoxs.com:6443/middleware/golang:1.22-alpine
  before_script:
    - apk add --no-cache git make                                     # private repo 私有 module 需要 git
  script:
    - go mod download
    - go build -trimpath -ldflags="-s -w" -o bin/${APP_NAME} ./cmd/${APP_NAME}
    - ls -lh bin/${APP_NAME}
    - file bin/${APP_NAME}                                            # 验证是 statically linked
  artifacts:
    expire_in: 1 day
    paths:
      - bin/

# ─────────────────────────────────────────────────────────────────────
# C) sonar-scan:SonarQube(没配自动跳过)
# Go 用 sonar-scanner-cli + sonar.go.coverage.reportPaths(可选)
# ─────────────────────────────────────────────────────────────────────
sonar-scan:
  stage: scan
  image:
    name: hub.wishfoxs.com:6443/middleware/sonar-scanner-cli:latest
    entrypoint: [""]
  needs:
    - job: build
      artifacts: false
  script:
    - sonar-scanner -Dsonar.projectKey=${APP_NAME} -Dsonar.sources=. -Dsonar.exclusions=vendor/** -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.token=${SONAR_TOKEN}
  rules:
    - if: '$SONAR_HOST_URL && $SONAR_TOKEN'

# ─────────────────────────────────────────────────────────────────────
# D) build-image:Kaniko + Harbor(多阶段 Dockerfile 推荐)
#
# 推荐 Dockerfile:
#   FROM hub.wishfoxs.com:6443/middleware/golang:1.22-alpine AS builder
#   WORKDIR /src
#   COPY . .
#   RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/myapp ./cmd/myapp
#
#   FROM hub.wishfoxs.com:6443/middleware/alpine:latest
#   COPY --from=builder /out/myapp /usr/local/bin/myapp
#   EXPOSE 8080
#   ENTRYPOINT ["/usr/local/bin/myapp"]
# ─────────────────────────────────────────────────────────────────────
build-image:
  stage: image
  image:
    name: hub.wishfoxs.com:6443/middleware/executor:debug
    entrypoint: [""]
  needs:
    - job: build
      artifacts: true
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  script:
    - echo "IMAGE_NAME=${IMAGE_NAME}"
    - mkdir -p /kaniko/.docker
    - |
      cat > /kaniko/.docker/config.json << EOF
      {"auths":{"${HARBOR_REGISTRY}":{"username":"${HARBOR_USERNAME}","password":"${HARBOR_PASSWORD}"}}}
      EOF
    - /kaniko/executor --context "${CI_PROJECT_DIR}" --dockerfile "${CI_PROJECT_DIR}/Dockerfile" --destination "${IMAGE_NAME}" --cache=true --verbosity=info

# ─────────────────────────────────────────────────────────────────────
# E) update-manifest:GitOps 核心(栈无关)
# 前置 GitLab UI 一次性配置:见 ../README.md § 接入流程 第 3 步
# ─────────────────────────────────────────────────────────────────────
update-manifest:
  stage: update-manifest
  image: hub.wishfoxs.com:6443/middleware/alpine:latest
  needs:
    - job: build-image
      artifacts: false
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  variables:
    GIT_STRATEGY: clone
    MANIFEST_FILE: k8s/deployment.yaml
  before_script:
    - apk add --no-cache git sed bash
    - git config --global user.email "gitlab-ci@myapp"
    - git config --global user.name  "GitLab CI"
  script:
    - |
      set -eu

      [ -n "${GITLAB_PUSH_TOKEN:-}" ] || {
        echo "ERROR: GITLAB_PUSH_TOKEN 未注入 — 检查 Variable Protected=Yes"; exit 1; }
      [ -n "${IMAGE_TAG:-}" ] || {
        echo "ERROR: IMAGE_TAG 空 — 检查 variables 段表达式"; exit 1; }

      echo "更新 ${MANIFEST_FILE} → ${IMAGE_TAG}"
      sed -i "s|\(myapp:\)[^\"' ]\+|\1${IMAGE_TAG}|" "${MANIFEST_FILE}"
      grep -q "myapp:${IMAGE_TAG}" "${MANIFEST_FILE}" || { echo "ERROR: 替换失败"; exit 1; }

      if git diff --quiet "${MANIFEST_FILE}"; then
        echo "manifest 已是目标 tag,跳过 push"; exit 0; fi

      git add "${MANIFEST_FILE}"
      git commit -m "chore(deploy): bump image tag → ${IMAGE_TAG} [skip ci]"

      AUTH_URL="${CI_SERVER_PROTOCOL}://oauth2:${GITLAB_PUSH_TOKEN}@${CI_SERVER_HOST}:${CI_SERVER_PORT}/${CI_PROJECT_PATH}.git"
      git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME} || {
        echo "push 撞 commit,pull --rebase 重试"
        git pull --rebase "${AUTH_URL}" "${CI_COMMIT_REF_NAME}"
        git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME}
      }
      echo "manifest 已 push,ArgoCD 轮询周期内 sync(立即触发:argocd app sync myapp)"
