# =============================================================================
# GitLab CI 完整模板 — Node.js / 前端栈(Vue / React / Vite / Next 等)
# 来源:vue3-demo(Vue3 + Vite),生产已验证
#
# 用法:
#   cp node.yml.example /path/to/your-app/.gitlab-ci.yml
#   sed -i 's/myapp/<your-app-name>/g' /path/to/your-app/.gitlab-ci.yml
#
# GitLab 项目一次性 UI 配置见 E 段顶部注释(Project Access Token + Protected branch + CI Variable)。
# 完整文档 + 12 条踩坑表见 ../README.md。
# =============================================================================

default:
  tags:
    - docker

stages:
  - install
  - build
  - scan
  - image
  - update-manifest

variables:
  APP_NAME: myapp
  HARBOR_REGISTRY: hub.wishfoxs.com:6443
  HARBOR_PROJECT: library
  # IMAGE_TAG 双轨:默认 branch-sha,tag pipeline 时 rules:variables override 成 $CI_COMMIT_TAG
  # ⚠ 不要写 ${CI_COMMIT_TAG:-fallback},GitLab CI variables 段不解析 bash 默认值语法
  IMAGE_TAG: "${CI_COMMIT_REF_SLUG}-${CI_COMMIT_SHORT_SHA}"
  IMAGE_NAME: "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/${APP_NAME}:${IMAGE_TAG}"
  NPM_CONFIG_CACHE: .npm

cache:
  key: npm-${CI_COMMIT_REF_SLUG}
  paths:
    - .npm/
    - node_modules/

# ─────────────────────────────────────────────────────────────────────
# A) install:npm install,registry 走 npmmirror 国内加速
# ─────────────────────────────────────────────────────────────────────
install:
  stage: install
  image: hub.wishfoxs.com:6443/middleware/node:18-alpine
  script:
    - npm install --registry=https://registry.npmmirror.com
  artifacts:
    expire_in: 1 hour
    paths:
      - node_modules/

# ─────────────────────────────────────────────────────────────────────
# B) build:Vite / Webpack / Rollup build,产物到 dist/
# ─────────────────────────────────────────────────────────────────────
build:
  stage: build
  image: hub.wishfoxs.com:6443/middleware/node:18-alpine
  needs:
    - job: install
      artifacts: true
  script:
    - npm run build
  artifacts:
    expire_in: 1 day
    paths:
      - dist/

# ─────────────────────────────────────────────────────────────────────
# C) sonar-scan:代码质量(SONAR_HOST_URL 没配自动跳过)
# ─────────────────────────────────────────────────────────────────────
sonar-scan:
  stage: scan
  image:
    name: hub.wishfoxs.com:6443/middleware/sonar-scanner-cli:latest
    entrypoint: [""]
  needs:
    - job: build
      artifacts: true
  script:
    - sonar-scanner -Dsonar.projectKey=${APP_NAME} -Dsonar.sources=src -Dsonar.host.url=${SONAR_HOST_URL} -Dsonar.token=${SONAR_TOKEN}
  rules:
    - if: '$SONAR_HOST_URL && $SONAR_TOKEN'

# ─────────────────────────────────────────────────────────────────────
# D) build-image:Kaniko 构镜像 + 推 Harbor(通用)
# 前置 CI/CD Variables:HARBOR_USERNAME / HARBOR_PASSWORD (Masked + Protected)
# Dockerfile:FROM nginx:alpine + COPY dist/(SPA 静态站,nginx.conf 加 try_files fallback)
# ─────────────────────────────────────────────────────────────────────
build-image:
  stage: image
  image:
    name: hub.wishfoxs.com:6443/middleware/executor:debug
    entrypoint: [""]
  needs:
    - job: build
      artifacts: true
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  script:
    - echo "IMAGE_NAME=${IMAGE_NAME}"
    - test -n "${HARBOR_USERNAME}" && echo "HARBOR_USERNAME is set" || echo "HARBOR_USERNAME is empty"
    - test -n "${HARBOR_PASSWORD}" && echo "HARBOR_PASSWORD is set" || echo "HARBOR_PASSWORD is empty"
    - mkdir -p /kaniko/.docker
    - |
      cat > /kaniko/.docker/config.json << EOF
      {"auths":{"${HARBOR_REGISTRY}":{"username":"${HARBOR_USERNAME}","password":"${HARBOR_PASSWORD}"}}}
      EOF
    - /kaniko/executor --context "${CI_PROJECT_DIR}" --dockerfile "${CI_PROJECT_DIR}/Dockerfile" --destination "${IMAGE_NAME}" --cache=true --verbosity=info

# ─────────────────────────────────────────────────────────────────────
# E) update-manifest:GitOps 核心 — 改 k8s/deployment.yaml + push,ArgoCD sync
#
# 前置(GitLab UI 一次性):
#   ① Settings → Access Tokens → Add new token
#        Role=Maintainer  Scopes=write_repository  Expire=90 天
#      复制 token + 记 bot username project_<id>_bot_<hash>
#   ② Settings → Repository → Protected branches → master
#        Allowed to push 含 Maintainers(默认覆盖 bot),或显式 Add member
#   ③ Settings → CI/CD → Variables → GITLAB_PUSH_TOKEN
#        Type=Variable  Protected=Yes(强制)  Masked=Yes
# ─────────────────────────────────────────────────────────────────────
update-manifest:
  stage: update-manifest
  image: hub.wishfoxs.com:6443/middleware/alpine:latest
  needs:
    - job: build-image
      artifacts: false
  rules:
    - if: '$CI_COMMIT_TAG'
      variables:
        IMAGE_TAG: "${CI_COMMIT_TAG}"
    - if: '$CI_COMMIT_BRANCH == "master"'
  variables:
    GIT_STRATEGY: clone
    MANIFEST_FILE: k8s/deployment.yaml
  before_script:
    - apk add --no-cache git sed bash
    - git config --global user.email "gitlab-ci@myapp"
    - git config --global user.name  "GitLab CI"
  script:
    - |
      set -eu

      [ -n "${GITLAB_PUSH_TOKEN:-}" ] || {
        echo "ERROR: GITLAB_PUSH_TOKEN 未注入 — 检查 Variable Protected=Yes"; exit 1; }
      [ -n "${IMAGE_TAG:-}" ] || {
        echo "ERROR: IMAGE_TAG 空 — 检查 variables 段表达式"; exit 1; }

      echo "更新 ${MANIFEST_FILE} → ${IMAGE_TAG}"
      sed -i "s|\(myapp:\)[^\"' ]\+|\1${IMAGE_TAG}|" "${MANIFEST_FILE}"
      grep -q "myapp:${IMAGE_TAG}" "${MANIFEST_FILE}" || { echo "ERROR: 替换失败"; exit 1; }

      if git diff --quiet "${MANIFEST_FILE}"; then
        echo "manifest 已是目标 tag,跳过 push"; exit 0; fi

      git add "${MANIFEST_FILE}"
      git commit -m "chore(deploy): bump image tag → ${IMAGE_TAG} [skip ci]"

      AUTH_URL="${CI_SERVER_PROTOCOL}://oauth2:${GITLAB_PUSH_TOKEN}@${CI_SERVER_HOST}:${CI_SERVER_PORT}/${CI_PROJECT_PATH}.git"
      git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME} || {
        echo "push 撞 commit,pull --rebase 重试"
        git pull --rebase "${AUTH_URL}" "${CI_COMMIT_REF_NAME}"
        git push "${AUTH_URL}" HEAD:${CI_COMMIT_REF_NAME}
      }
      echo "manifest 已 push,ArgoCD 轮询周期内 sync(立即触发:argocd app sync myapp)"
